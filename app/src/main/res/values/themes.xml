<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TempRes" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- NIYUVA Splash Theme — uses Android 12+ SplashScreen API -->
    <!-- Background matches our custom SplashScreen composable background -->
    <style name="Theme.Niyuva.Splash" parent="Theme.SplashScreen">
        <!-- Plum rose background so there is zero white flash -->
        <item name="windowSplashScreenBackground">#8B5E6D</item>
        <!-- Use our vector splash logo as the splash icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <!-- After splash, switch to our transparent no-action-bar app theme -->
        <item name="postSplashScreenTheme">@android:style/Theme.Material.Light.NoActionBar</item>
    </style>

</resources>